<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Retirement Countdown</title>
  <style>
    :root {
      --bg: #071f1a;
      --bg-dark: #041512;
      --tile: #123b32;
      --accent: #7ddf9c;
      --gold: #e7c76f;
      --text: #f4f7ef;
      --muted: #a9b9ae;
      --line: rgba(244, 247, 239, 0.14);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--bg), var(--bg-dark));
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      display: flex;
      justify-content: center;
      align-items: flex-end; /* Aligns the container to the bottom */
      padding: 20px;
      padding-bottom: 60px; /* Adjust this value to set the exact distance from the bottom */
    }

    .countdown-container {
      background: var(--tile);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 40px;
      text-align: center;
      box-shadow: 0 20px 50px rgba(0,0,0,0.3);
      max-width: 500px;
      width: 100%;
    }

    .title {
      font-size: 20px;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--accent);
      margin-bottom: 8px;
      font-weight: 700;
    }

    .subtitle {
      font-size: 14px;
      color: var(--muted);
      margin-bottom: 30px;
    }

    .clock {
      font-size: 48px;
      font-weight: 850;
      color: var(--gold);
      letter-spacing: 2px;
      font-variant-numeric: tabular-nums;
    }

    .labels {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      margin-top: 8px;
      padding: 0 10px;
    }

    .label-item {
      font-size: 11px;
      text-transform: uppercase;
      color: var(--muted);
      letter-spacing: 1px;
      font-weight: 600;
    }
  </style>
</head>
<body>

  <div class="countdown-container">
    <div class="title">Retirement Countdown</div>
    <div class="subtitle">Until September 17, 2028</div>
    
    <div class="clock" id="countdownClock">00:00:00:00</div>
    
    <div class="labels">
      <div class="label-item">Days</div>
      <div class="label-item">Hrs</div>
      <div class="label-item">Min</div>
